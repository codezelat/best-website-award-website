    "@lucide/astro": "^1.24.0",
    "@tailwindcss/vite": "^4.3.3",
    "astro": "^7.1.0",
    "motion": "^12.42.2",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.0",
