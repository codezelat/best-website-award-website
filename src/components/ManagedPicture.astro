---
import { Picture } from 'astro:assets';
import type { ManagedImage } from '../lib/content/types';

interface Props {
  image: ManagedImage;
  class?: string;
  loading?: 'eager' | 'lazy';
  fetchpriority?: 'high' | 'low' | 'auto';
  sizes?: string;
  widths?: number[];
  quality?: number;
  formats?: Array<'avif' | 'webp'>;
  decoding?: 'async' | 'sync' | 'auto';
}

const {
  image,
  class: className,
  loading = 'lazy',
  fetchpriority = 'auto',
  sizes = '(min-width: 1100px) 50vw, 100vw',
  widths = [480, 640, 720, 960, 1280, 1600],
  quality = 82,
  formats = ['avif'],
  decoding = 'async'
} = Astro.props;

const style = image.position ? `object-position:${image.position}` : undefined;
---

{
  typeof image.src === 'string' ? (
    <img
      class={className}
      src={image.src}
      alt={image.alt}
      width={image.width}
      height={image.height}
      loading={loading}
      {decoding}
      fetchpriority={fetchpriority}
      style={style}
    />
  ) : (
    <Picture
      class={className}
      src={image.src}
      alt={image.alt}
      widths={widths}
      sizes={sizes}
      {formats}
      fallbackFormat="webp"
      loading={loading}
      {decoding}
      fetchpriority={fetchpriority}
      {quality}
      style={style}
    />
  )
}
