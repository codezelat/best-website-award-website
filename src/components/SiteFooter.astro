---
import type { NavigationItem } from '../lib/content/types';
import BrandLogo from './BrandLogo.astro';

interface Props {
  navigation: NavigationItem[];
  legalNavigation?: NavigationItem[];
  currentPath?: string;
}

const { navigation, legalNavigation = [], currentPath = '/' } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container site-footer__top">
    <a href="#top" class="site-footer__brand" aria-label="Back to top">
      <BrandLogo variant="reversed" loading="lazy" />
    </a>
    <nav class="site-footer__nav" aria-label="Footer navigation">
      {
        navigation.map((item) => (
          <a href={item.href} aria-current={currentPath === item.href ? 'page' : undefined}>
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
  {
    legalNavigation.length > 0 && (
      <nav class="container site-footer__legal" aria-label="Legal and contact navigation">
        {legalNavigation.map((item) => (
          <a href={item.href} aria-current={currentPath === item.href ? 'page' : undefined}>
            {item.label}
          </a>
        ))}
        <button type="button" data-open-analytics-settings>
          Cookie settings
        </button>
      </nav>
    )
  }
  <div class="container site-footer__bottom">
    <p>© {year} Best Website Awards. All rights reserved.</p>
    <a href="#top">Back to top</a>
  </div>
</footer>

<script>
  document.querySelector('[data-open-analytics-settings]')?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('bwa:open-analytics-settings'));
  });
</script>
