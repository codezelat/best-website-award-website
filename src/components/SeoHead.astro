---
import type { PageSeo, UtilitySection } from '../lib/content/types';
import { socialLinks } from '../data/site';

interface Props {
  title: string;
  description: string;
  canonical: URL;
  image: URL;
  imageAlt: string;
  imageWidth?: number;
  imageHeight?: number;
  pageType?: PageSeo['pageType'];
  noIndex?: boolean;
  faqItems?: UtilitySection[];
  structuredImages?: Array<{
    url: URL;
    caption: string;
    width?: number;
    height?: number;
  }>;
}

const {
  title,
  description,
  canonical,
  image,
  imageAlt,
  imageWidth,
  imageHeight,
  pageType = 'WebPage',
  noIndex = false,
  faqItems = [],
  structuredImages = []
} = Astro.props;

const siteId = `${canonical.origin}/#website`;
const organizationId = `${canonical.origin}/#organization`;
const pageId = `${canonical.href}#webpage`;
const isHomepage = canonical.pathname === '/';
const breadcrumbId = `${canonical.href}#breadcrumb`;
const pageName = title.replace(/\s*\|\s*Best Website Awards$/, '');
const galleryImageNodes = structuredImages.map((item, index) => ({
  '@type': 'ImageObject',
  '@id': `${pageId}/image/${index + 1}`,
  contentUrl: item.url.href,
  url: item.url.href,
  caption: item.caption,
  ...(item.width ? { width: item.width } : {}),
  ...(item.height ? { height: item.height } : {})
}));

const pageNode: Record<string, unknown> = {
  '@type': pageType,
  '@id': pageId,
  url: canonical.href,
  name: title,
  description,
  inLanguage: 'en-GB',
  isPartOf: { '@id': siteId },
  about: { '@id': organizationId },
  primaryImageOfPage: {
    '@type': 'ImageObject',
    contentUrl: image.href,
    url: image.href,
    caption: imageAlt,
    ...(imageWidth ? { width: imageWidth } : {}),
    ...(imageHeight ? { height: imageHeight } : {})
  }
};

if (!isHomepage) {
  pageNode.breadcrumb = { '@id': breadcrumbId };
}

if (galleryImageNodes.length > 0) {
  pageNode.hasPart = galleryImageNodes.map((item) => ({ '@id': item['@id'] }));
}

if (pageType === 'FAQPage' && faqItems.length > 0) {
  pageNode.mainEntity = faqItems.map((item) => ({
    '@type': 'Question',
    name: item.title,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.body.join('\n\n')
    }
  }));
}

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': siteId,
      url: `${canonical.origin}/`,
      name: 'Best Website Awards',
      alternateName: 'BWA',
      description:
        'A global awards platform recognising website excellence across design, experience, performance, accessibility, content, purpose, innovation and impact.',
      inLanguage: 'en-GB',
      publisher: { '@id': organizationId }
    },
    {
      '@type': 'Organization',
      '@id': organizationId,
      name: 'Best Website Awards',
      alternateName: 'BWA',
      url: `${canonical.origin}/`,
      email: 'info@gbeaward.com',
      areaServed: 'Worldwide',
      contactPoint: {
        '@type': 'ContactPoint',
        contactType: 'programme enquiries',
        email: 'info@gbeaward.com',
        availableLanguage: 'English'
      },
      sameAs: socialLinks.filter((item) => item.network !== 'whatsapp').map((item) => item.href),
      logo: {
        '@type': 'ImageObject',
        url: `${canonical.origin}/favicon.png`
      },
      parentOrganization: {
        '@type': 'Organization',
        name: 'Global Business Excellence Awards',
        url: 'https://gbeaward.com/'
      }
    },
    ...(!isHomepage
      ? [
          {
            '@type': 'BreadcrumbList',
            '@id': breadcrumbId,
            itemListElement: [
              {
                '@type': 'ListItem',
                position: 1,
                name: 'Best Website Awards',
                item: `${canonical.origin}/`
              },
              {
                '@type': 'ListItem',
                position: 2,
                name: pageName,
                item: canonical.href
              }
            ]
          }
        ]
      : []),
    pageNode,
    ...galleryImageNodes
  ]
};
---

<title>{title}</title>
<meta name="description" content={description} />
<meta
  name="robots"
  content={noIndex
    ? 'noindex, follow'
    : 'index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1'}
/>
<link rel="canonical" href={canonical} />

<meta property="og:type" content="website" />
<meta property="og:locale" content="en_GB" />
<meta property="og:site_name" content="Best Website Awards" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={image} />
<meta property="og:image:secure_url" content={image} />
<meta property="og:image:alt" content={imageAlt} />
{imageWidth && <meta property="og:image:width" content={String(imageWidth)} />}
{imageHeight && <meta property="og:image:height" content={String(imageHeight)} />}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={image} />
<meta name="twitter:image:alt" content={imageAlt} />

<script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
