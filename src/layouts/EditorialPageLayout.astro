---
import EditorialClosing from '../components/EditorialClosing.astro';
import EditorialCollection from '../components/EditorialCollection.astro';
import EditorialFeature from '../components/EditorialFeature.astro';
import EditorialIntroduction from '../components/EditorialIntroduction.astro';
import EditorialPageHero from '../components/EditorialPageHero.astro';
import EditorialStatement from '../components/EditorialStatement.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { legalNavigation, siteNavigation } from '../data/site';
import type { EditorialPageContent } from '../lib/content/types';
import { resolveManagedImage, resolveManagedImages } from '../lib/seo/images';
import BaseLayout from './BaseLayout.astro';

interface Props {
  content: EditorialPageContent;
}

const { content } = Astro.props;
const primaryImage = resolveManagedImage(content.hero.image, Astro.site);
const structuredImages = resolveManagedImages(
  [
    ...content.primaryCollection.items.flatMap((item) => (item.image ? [item.image] : [])),
    ...(content.secondaryCollection?.items.flatMap((item) => (item.image ? [item.image] : [])) ??
      []),
    ...(content.feature?.image ? [content.feature.image] : [])
  ],
  Astro.site
);
---

<BaseLayout
  title={content.seo.title}
  description={content.seo.description}
  image={primaryImage.url}
  imageAlt={content.hero.image.alt}
  imageWidth={primaryImage.width}
  imageHeight={primaryImage.height}
  pageType={content.seo.pageType}
  noIndex={content.seo.noIndex}
  {structuredImages}
>
  <div id="top"></div>
  <SiteHeader navigation={siteNavigation} currentPath={Astro.url.pathname} />
  <main id="main-content">
    <EditorialPageHero content={content.hero} />
    <EditorialIntroduction content={content.introduction} />
    <EditorialCollection content={content.primaryCollection} />
    {
      content.secondaryCollection && (
        <EditorialCollection content={content.secondaryCollection} secondary />
      )
    }
    {content.feature && <EditorialFeature content={content.feature} />}
    <EditorialStatement
      content={content.statement}
      showBrand={content.slug === 'awards' || content.slug === 'about'}
    />
    <EditorialClosing content={content.closing} />
  </main>
  <SiteFooter
    navigation={siteNavigation}
    legalNavigation={legalNavigation}
    currentPath={Astro.url.pathname}
  />
</BaseLayout>
