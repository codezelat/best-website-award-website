---
import ButtonLink from '../components/ButtonLink.astro';
import ContactForm from '../components/ContactForm.astro';
import FaqList from '../components/FaqList.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { legalNavigation, siteNavigation } from '../data/site';
import type { UtilityPageContent } from '../lib/content/types';
import iconmark from '../assets/brand/iconmark.png';
import BaseLayout from './BaseLayout.astro';

interface Props {
  content: UtilityPageContent;
}

const { content } = Astro.props;
const socialImage = new URL(iconmark.src, Astro.site);
const getSectionId = (title: string, index: number) => {
  const slug = title
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '');

  return `${content.slug}-${slug || `section-${index + 1}`}`;
};
---

<BaseLayout
  title={content.seo.title}
  description={content.seo.description}
  image={socialImage}
  imageAlt={`Best Website Awards: ${content.title}`}
  pageType={content.seo.pageType}
  noIndex={content.seo.noIndex}
  faqItems={content.slug === 'faq' ? content.sections : undefined}
>
  <div id="top"></div>
  <SiteHeader navigation={siteNavigation} currentPath={Astro.url.pathname} />
  <main id="main-content" class="tw:bg-white">
    <header class="tw:border-b tw:border-line tw:py-[clamp(5rem,10vw,10rem)]">
      <div class="container tw:grid tw:gap-10 tw:lg:grid-cols-[1fr_.75fr] tw:lg:items-end">
        <h1 class="tw:max-w-none tw:sm:max-w-[10ch]" data-hero-reveal>{content.title}</h1>
        <div>
          <p
            class="tw:max-w-[40rem] tw:text-[clamp(1.15rem,1.8vw,1.5rem)] tw:leading-[1.55] tw:text-ink-soft"
            data-hero-reveal
          >
            {content.introduction}
          </p>
          {
            content.action && (
              <div class="tw:mt-8" data-hero-reveal>
                <ButtonLink {...content.action} variant="primary" />
              </div>
            )
          }
        </div>
      </div>
    </header>

    {content.slug === 'contact' && <ContactForm />}

    {
      content.slug === 'faq' ? (
        <FaqList sections={content.sections} />
      ) : (
        <div class="container tw:py-[clamp(5rem,9vw,9rem)]">
          <div class="tw:mx-auto tw:max-w-[72rem] tw:border-t tw:border-carbon" data-reveal-group>
            {content.sections.map((section, index) => (
              <section
                class="utility-section tw:scroll-mt-32 tw:grid tw:min-w-0 tw:gap-6 tw:border-b tw:border-line tw:py-[clamp(2.5rem,5vw,4.5rem)] tw:xl:grid-cols-[4.5rem_minmax(0,.78fr)_minmax(0,1.22fr)] tw:xl:gap-x-[clamp(2rem,4vw,4.5rem)]"
                id={getSectionId(section.title, index)}
                aria-labelledby={`${getSectionId(section.title, index)}-title`}
                data-reveal
              >
                <span class="tw:text-[.75rem] tw:font-bold tw:tracking-[.12em] tw:text-lapis">
                  {String(index + 1).padStart(2, '0')}
                </span>
                <h2
                  id={`${getSectionId(section.title, index)}-title`}
                  class="utility-section__heading tw:min-w-0 tw:max-w-[15ch] tw:[overflow-wrap:anywhere]"
                  data-utility-heading
                >
                  {section.title}
                </h2>
                <div class="tw:grid tw:min-w-0 tw:gap-4" data-utility-copy>
                  {section.body.map((paragraph) => (
                    <p class="tw:max-w-[42rem] tw:leading-[1.7] tw:text-ink-soft">{paragraph}</p>
                  ))}
                </div>
              </section>
            ))}
          </div>
        </div>
      )
    }
  </main>
  <SiteFooter
    navigation={siteNavigation}
    legalNavigation={legalNavigation}
    currentPath={Astro.url.pathname}
  />
</BaseLayout>
