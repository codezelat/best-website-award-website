---
import '@fontsource-variable/funnel-display/index.css';
import '@fontsource-variable/funnel-sans/index.css';
import '../styles/global.css';
import PageLoader from '../components/PageLoader.astro';
import AnalyticsConsent from '../components/AnalyticsConsent.astro';
import SeoHead from '../components/SeoHead.astro';
import type { PageSeo, UtilitySection } from '../lib/content/types';

interface Props {
  title: string;
  description: string;
  image: URL;
  imageAlt?: string;
  imageWidth?: number;
  imageHeight?: number;
  pageType?: PageSeo['pageType'];
  noIndex?: boolean;
  faqItems?: UtilitySection[];
  structuredImages?: Array<{
    url: URL;
    caption: string;
    width?: number;
    height?: number;
  }>;
}

const {
  title,
  description,
  image,
  imageAlt = 'Best Website Awards: global recognition for website excellence',
  imageWidth,
  imageHeight,
  pageType = 'WebPage',
  noIndex = false,
  faqItems,
  structuredImages = []
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#1746d1" />
    <meta name="color-scheme" content="light" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <SeoHead
      {title}
      {description}
      {canonical}
      {image}
      {imageAlt}
      {imageWidth}
      {imageHeight}
      {pageType}
      {noIndex}
      {faqItems}
      {structuredImages}
    />
    <script is:inline>
      document.documentElement.classList.add('js');
      window.dataLayer = window.dataLayer || [];
      window.gtag = function () {
        window.dataLayer.push(arguments);
      };
      window.gtag('consent', 'default', {
        ad_storage: 'denied',
        analytics_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        wait_for_update: 500
      });
      window.gtag('set', 'ads_data_redaction', true);
    </script>
  </head>
  <body>
    <PageLoader />
    <a class="skip-link" href="#main-content">Skip to content</a>
    <slot />
    <AnalyticsConsent />
    <script>
      import '../scripts/site-motion';
    </script>
  </body>
</html>
