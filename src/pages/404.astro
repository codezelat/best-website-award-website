---
import UtilityPageLayout from '../layouts/UtilityPageLayout.astro';
import { getUtilityPage } from '../lib/content/pages';

export const prerender = true;

const content = await getUtilityPage('notFound');

if (!content) {
  throw new Error('Missing content for the not-found page.');
}
---

<UtilityPageLayout {content} />
